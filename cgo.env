export CGO_ENABLED=1
export CGO_CFLAGS="-Wno-deprecated-declarations $(find /opt/ros/jazzy/include -mindepth 1 -maxdepth 1 -type d | sed 's/^/-I/' | tr '\n' ' ')"
export CGO_LDFLAGS="-L/opt/ros/jazzy/lib -L/opt/ros/jazzy/lib/aarch64-linux-gnu"
export PKG_CONFIG_PATH="/opt/ros/jazzy/lib/pkgconfig:/opt/ros/jazzy/lib/aarch64-linux-gnu/pkgconfig:$PKG_CONFIG_PATH"
export LD_LIBRARY_PATH="/opt/ros/jazzy/lib:/opt/ros/jazzy/lib/aarch64-linux-gnu:$LD_LIBRARY_PATH"
